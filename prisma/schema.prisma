// prisma/schema.prisma

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================
// ENUMS
// ===========================

enum Role {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  EMPLOYEE
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  HALF_DAY
  ON_LEAVE
}

enum CheckType {
  CHECK_IN
  CHECK_OUT
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  SICK
  ANNUAL
  EMERGENCY
  UNPAID
  MATERNITY
  PATERNITY
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
  FLEXIBLE
}

// ===========================
// MODELS
// ===========================

model Company {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  address     String?
  phone       String?
  email       String?
  logoUrl     String?
  timezone    String   @default("Asia/Jakarta")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  locations   Location[]
  users       User[]
  shifts      Shift[]
  policies    AttendancePolicy[]

  @@map("companies")
}

model Location {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  address     String
  latitude    Float
  longitude   Float
  radius      Float    @default(100) // radius in meters
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attendances Attendance[]
  assignments UserLocation[]

  @@map("locations")
}

model UserLocation {
  id         String   @id @default(cuid())
  userId     String
  locationId String
  assignedAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
  @@map("user_locations")
}

model User {
  id              String    @id @default(cuid())
  companyId       String
  employeeId      String    @unique // NIK / Employee number
  email           String    @unique
  phone           String?
  password        String
  fullName        String
  role            Role      @default(EMPLOYEE)
  avatarUrl       String?
  department      String?
  position        String?
  shiftId         String?
  supervisorId    String?
  isActive        Boolean   @default(true)
  emailVerified   Boolean   @default(false)
  lastLoginAt     DateTime?
  refreshToken    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company         Company        @relation(fields: [companyId], references: [id])
  shift           Shift?         @relation(fields: [shiftId], references: [id])
  supervisor      User?          @relation("SupervisorEmployee", fields: [supervisorId], references: [id])
  subordinates    User[]         @relation("SupervisorEmployee")
  locations       UserLocation[]
  attendances     Attendance[]
  leaveRequests   LeaveRequest[]
  deviceTokens    DeviceToken[]
  activityLogs    ActivityLog[]

  @@map("users")
}

model Shift {
  id          String    @id @default(cuid())
  companyId   String
  name        String
  type        ShiftType @default(MORNING)
  startTime   String    // "08:00"
  endTime     String    // "17:00"
  lateThreshold  Int   @default(15) // minutes tolerance
  earlyCheckout  Int   @default(15) // minutes before end
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company    @relation(fields: [companyId], references: [id])
  users       User[]
  attendances Attendance[]

  @@map("shifts")
}

model AttendancePolicy {
  id                   String   @id @default(cuid())
  companyId            String   @unique
  maxLateMinutes       Int      @default(15)
  autoAbsentAfterHours Int      @default(4)  // if no check-in after X hours
  requireSelfie        Boolean  @default(true)
  requireLocation      Boolean  @default(true)
  workingDays          String[] @default(["MON","TUE","WED","THU","FRI"])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@map("attendance_policies")
}

model Attendance {
  id              String           @id @default(cuid())
  userId          String
  locationId      String?
  shiftId         String?
  date            DateTime         @db.Date
  status          AttendanceStatus @default(PRESENT)
  
  // Check-in data
  checkInTime     DateTime?
  checkInLat      Float?
  checkInLng      Float?
  checkInDistance Float?           // distance from location center in meters
  checkInSelfie   String?          // photo URL
  checkInNote     String?
  checkInDevice   String?
  isCheckInValid  Boolean          @default(false)

  // Check-out data
  checkOutTime    DateTime?
  checkOutLat     Float?
  checkOutLng     Float?
  checkOutDistance Float?
  checkOutSelfie  String?
  checkOutNote    String?
  isCheckOutValid Boolean          @default(false)

  // Computed
  workDuration    Int?             // in minutes
  lateMinutes     Int?             @default(0)
  overtimeMinutes Int?             @default(0)

  // Admin
  isManualEntry   Boolean          @default(false)
  approvedBy      String?
  approvedAt      DateTime?
  adminNote       String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user            User             @relation(fields: [userId], references: [id])
  location        Location?        @relation(fields: [locationId], references: [id])
  shift           Shift?           @relation(fields: [shiftId], references: [id])

  @@unique([userId, date])
  @@index([date])
  @@index([userId, date])
  @@map("attendances")
}

model LeaveRequest {
  id          String      @id @default(cuid())
  userId      String
  type        LeaveType
  status      LeaveStatus @default(PENDING)
  startDate   DateTime    @db.Date
  endDate     DateTime    @db.Date
  totalDays   Int
  reason      String
  attachment  String?
  reviewedBy  String?
  reviewNote  String?
  reviewedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id])

  @@map("leave_requests")
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   // "android" | "ios" | "web"
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  module    String
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("activity_logs")
}
